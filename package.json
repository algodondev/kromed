{
  "name": "kromed",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:ui": "playwright test",
    "db:start": "npx supabase start",
    "db:reset": "npx supabase db reset --local",
    "db:test": "npx supabase test db --local supabase/tests",
    "db:lint": "npx supabase db lint --local --schema public --fail-on error",
    "db:advisors": "npx supabase db advisors --local --type all --level warn --fail-on error",
    "db:types": "npx supabase gen types --local --schema public > /tmp/kromed.database.types.ts && mv /tmp/kromed.database.types.ts lib/database.types.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
